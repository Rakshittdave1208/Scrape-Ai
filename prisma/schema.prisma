generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Workflow {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  definition  String
  status      String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, userId])
}
model Credential {
  id          String   @id @default(cuid())
  userId      String
  name        String
  type        String
  value       String?
  apiKey      String?
  username    String?
  password    String?
  cookieValue String?
  customHeaders String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, userId])
}
